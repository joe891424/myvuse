<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:focusable="true"
    android:longClickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RadioButton
        android:textColor="@color/yoti_theme_state_typography_neutral_contrast"
        android:ellipsize="end"
        android:id="@+id/radio_button"
        android:background="@null"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:button="@null"
        android:singleLine="true"
        android:importantForAccessibility="no"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_additional"
        app:layout_constraintEnd_toStartOf="@+id/radiobutton_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:ellipsize="end"
        android:id="@+id/tv_additional"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:layout_centerVertical="true"
        android:lineSpacingMultiplier="1.25"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/radio_button"
        app:layout_constraintStart_toStartOf="@+id/radio_button"
        app:layout_constraintTop_toBottomOf="@+id/radio_button"/>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/radiobutton_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:importantForAccessibility="no"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/radio_button"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_fileName="lottie/radiobutton_indicator_selected.json"
        app:lottie_loop="false"/>
</androidx.constraintlayout.widget.ConstraintLayout>
