<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/yds_document_selection_description_or"
        style="@style/Yds.TextView.Header"/>
    <com.yoti.mobile.android.common.p049ui.widgets.button.YotiOptionButton
        android:id="@+id/buttonDoNotHaveDocuments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:optionLeftIconVisibility="gone"/>
</LinearLayout>
