<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/main_layout"
    android:paddingLeft="@dimen/ot_margin_small"
    android:paddingRight="@dimen/ot_margin_small"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/ot_margin_medium"
    android:weightSum="10"
    android:paddingStart="@dimen/ot_margin_small"
    android:paddingEnd="@dimen/ot_margin_small">
    <TextView
        android:textSize="@dimen/ot_subtitle_text_size"
        android:id="@+id/item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="5"/>
    <TextView
        android:textSize="@dimen/ot_description_text_size"
        android:gravity="end"
        android:id="@+id/item_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableRight="0x7f0802da"
        android:drawablePadding="@dimen/ot_margin_medium"
        android:layout_weight="5"/>
</LinearLayout>
