<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textAppearance="@style/Yds.Text.StepTracker.Num.Current"
        android:id="@+id/stepNumber"
        android:background="@drawable/yds_steptracker_step_incomplete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Yds.Text.StepTracker.Num"/>
    <TextView
        android:id="@+id/stepTitle"
        android:paddingTop="4dp"
        android:paddingBottom="40dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/yds_horizontal_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/stepNumber"
        app:layout_constraintTop_toTopOf="@+id/stepNumber"
        style="@style/Yds.TextView.Text"/>
    <View
        android:id="@+id/verticalLine"
        android:background="?attr/border_default"
        android:layout_width="3dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/stepTitle"
        app:layout_constraintEnd_toEndOf="@+id/stepNumber"
        app:layout_constraintHeight_default="spread"
        app:layout_constraintStart_toStartOf="@+id/stepNumber"
        app:layout_constraintTop_toBottomOf="@+id/stepNumber"/>
</androidx.constraintlayout.widget.ConstraintLayout>
