<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/mb_overlay_camera_translucent"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/mb_reticle_overlay_onboarding_margin"
        android:layout_marginVertical="@dimen/mb_reticle_overlay_onboarding_margin">
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/viewPager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <FrameLayout
            android:id="@+id/instructionsBottomBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mb_reticle_overlay_onboarding_height_bottom_bar"
            android:layout_alignParentBottom="true">
            <Button
                android:layout_gravity="start|center_vertical"
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/MBOnboardingButtonBorderless"/>
            <Button
                android:layout_gravity="start|center_vertical"
                android:id="@+id/btnBack"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/MBOnboardingButtonBorderless"/>
            <Button
                android:layout_gravity="end|center_vertical"
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/MBOnboardingButtonBorderless"/>
            <Button
                android:layout_gravity="end|center_vertical"
                android:id="@+id/btnDone"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/MBOnboardingButtonBorderless"/>
        </FrameLayout>
    </RelativeLayout>
</FrameLayout>
