<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/Qualtrics.MobileEmbeddedFeedback.Theme"
    android:orientation="vertical"
    android:id="@+id/embeddedFeedbackFollowupQuestionBody"
    android:background="@drawable/embedded_feedback_modal_border"
    android:focusable="false"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="35dp">
        <ImageButton
            android:id="@+id/close_button"
            android:background="#ffffff"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/close_16dp"
            android:contentDescription="@string/qualtrics_close_button"
            android:layout_marginStart="16dp"
            android:layout_alignParentEnd="true"/>
        <androidx.core.widget.NestedScrollView
            android:orientation="vertical"
            android:id="@+id/scroll_view"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="35dp"
            android:layout_below="@+id/close_button">
            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="20sp"
                    android:id="@+id/multiple_choice_question_text"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <RadioGroup
                    android:orientation="vertical"
                    android:id="@+id/multiple_choice_radio_group"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="20sp"
                    android:id="@+id/followup_question_text"
                    android:paddingBottom="16dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <EditText
                    android:textColorHint="@color/transparent"
                    android:gravity="top"
                    android:id="@+id/open_text_input"
                    android:background="@drawable/rounded_rectangle"
                    android:padding="15dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:inputType="textMultiLine"/>
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="20dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingTop="45dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:background="#00ffffff"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>
        <LinearLayout
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <androidx.appcompat.widget.AppCompatButton
                android:layout_gravity="bottom"
                android:id="@+id/submit_button"
                android:background="@drawable/rounded_rectangle"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="48dp"
                android:contentDescription="@string/qualtrics_submit_button"
                android:backgroundTint="@null"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
