<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/facetec_default_foreground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="25sp"
            android:textColor="@color/facetec_alert_green"
            android:id="@+id/alertIcon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/facetec_sdk_icon_attention_fill"
            android:includeFontPadding="false"
            android:layout_marginStart="20dp"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/facetec_default_tab_success_background"
            android:id="@+id/alertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text=""
            android:includeFontPadding="false"
            android:layout_marginStart="50dp"/>
    </RelativeLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/facetec_default_tab_success_background"
        android:id="@+id/alertMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:includeFontPadding="false"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <Button
            android:textColor="@android:color/white"
            android:id="@+id/doneButton"
            android:background="@color/facetec_alert_green"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""
            android:includeFontPadding="false"/>
    </RelativeLayout>
</LinearLayout>
