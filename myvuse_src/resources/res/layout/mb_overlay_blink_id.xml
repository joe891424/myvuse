<?xml version="1.0" encoding="utf-8"?>
<com.microblink.fragment.overlay.blinkid.reticleui.TouchInterceptRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/touchInterceptView"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/mb_top_button_bar"/>
    <com.microblink.fragment.overlay.components.feedback.view.SuccessFlashView
        android:id="@+id/successFlashView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.microblink.fragment.overlay.blinkid.reticleui.PulseView
        android:id="@+id/pulseView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.microblink.fragment.overlay.blinkid.reticleui.ReticleView
        android:id="@+id/reticleView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <ProgressBar
        android:id="@+id/progressBar"
        android:visibility="gone"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:indeterminate="true"
        android:indeterminateDrawable="@drawable/mb_reticle_progress"
        android:indeterminateDuration="500"
        android:layout_centerInParent="true"/>
    <TextSwitcher
        android:gravity="center"
        android:id="@+id/instructionsView"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="60dp"
        android:layout_marginTop="32dp"
        android:layout_marginRight="60dp"
        android:measureAllChildren="false"
        android:layout_below="@+id/reticleView"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/cardAnimationView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <ImageView
        android:id="@+id/poweredByMicroblinkView"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:src="0x7f0802b1"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:gravity="center"
        android:id="@+id/onboardingTooltip"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/mb_reticle_overlay_onboarding_tooltip_margin_end"
        android:layout_marginBottom="2dp"
        android:layout_above="@+id/blinkidHelpButton"
        android:layout_alignParentRight="true"
        android:layout_marginEnd="@dimen/mb_reticle_overlay_onboarding_tooltip_margin_end"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="@dimen/mb_reticle_overlay_onboarding_tooltip_padding"/>
    <ImageButton
        android:id="@+id/blinkidHelpButton"
        android:background="@color/mb_transparent"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/mb_reticle_overlay_onboarding_button_margin_end"
        android:layout_marginBottom="@dimen/mb_reticle_overlay_onboarding_button_margin_bottom"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="@dimen/mb_reticle_overlay_onboarding_button_margin_end"
        android:layout_alignParentEnd="true"/>
    <ViewSwitcher
        android:id="@+id/snackbarViewSwitcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
    <include
        android:id="@+id/onboarding"
        android:visibility="gone"
        layout="@layout/mb_blinkid_onboarding"/>
</com.microblink.fragment.overlay.blinkid.reticleui.TouchInterceptRelativeLayout>
