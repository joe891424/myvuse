<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/default_photopay_viewfinder"
    android:background="@drawable/mb_gradient_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextSwitcher
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/defaultStatusTextSwitcher"
        android:background="@drawable/mb_rounded_border"
        android:padding="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:measureAllChildren="false"
        android:minWidth="1dp"
        android:minHeight="1dp"
        android:drawablePadding="10dp"/>
    <include layout="@layout/mb_top_button_bar"/>
</FrameLayout>
