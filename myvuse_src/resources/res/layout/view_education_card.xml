<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="24dp">
    <ImageView
        android:id="@+id/centerCardIcon"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"
        app:layout_constraintBottom_toTopOf="@+id/cardTitle"
        app:layout_constraintEnd_toEndOf="@+id/cardText"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/startCardIcon"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textColor="@color/yoti_theme_state_typography_neutral_contrast"
        android:id="@+id/cardTitle"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/cardText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toBottomOf="@+id/centerCardIcon"/>
    <TextView
        android:textColor="@color/yoti_theme_state_typography_neutral_mid"
        android:id="@+id/cardText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/buttonBarrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/startCardIcon"
        app:layout_constraintTop_toBottomOf="@+id/cardTitle"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/buttonBarrier"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:barrierAllowsGoneWidgets="false"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="cardText"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:gravity="center_vertical"
        android:id="@+id/cardLinkSmall"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:minHeight="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/cardText"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toBottomOf="@+id/buttonBarrier"
        app:layout_goneMarginStart="16dp"
        style="@style/Yoti.v4.Button.Text.Small"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:gravity="center_vertical"
        android:id="@+id/cardLinkMedium"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:minHeight="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/cardText"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toBottomOf="@+id/buttonBarrier"
        app:layout_goneMarginStart="16dp"
        style="@style/Yoti.v4.Button.Text"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:id="@+id/cardButtonSmall"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        app:icon="@drawable/chevron_right_white"
        app:iconGravity="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toBottomOf="@+id/buttonBarrier"
        style="@style/Yoti.v4.Button.Primary.Small.Icon"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:id="@+id/cardButtonMedium"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        app:icon="@drawable/chevron_right_white"
        app:iconGravity="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/cardText"
        app:layout_constraintTop_toBottomOf="@+id/buttonBarrier"
        style="@style/Yoti.v4.Button.Primary.Icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
