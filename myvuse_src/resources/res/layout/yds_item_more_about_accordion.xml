<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/yds_root_view_horizontal_padding"
    android:paddingEnd="@dimen/yds_root_view_horizontal_padding">
    <com.yoti.mobile.android.common.p049ui.widgets.YotiAccordion
        android:id="@+id/accordion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:yotiAccordionExpanded="false"
        app:yotiAccordionExpandedIcon="@drawable/ico_chevron_right"
        app:yotiAccordionExpandedIconTint="?attr/icon_neutral_mid"/>
    <View
        android:background="?attr/border_default"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"/>
</LinearLayout>
