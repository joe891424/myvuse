<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonLivenessGuidelinesGotIt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.yoti.mobile.android.common.p049ui.widgets.YotiAppbar
                android:id="@+id/appBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/livenessGuidelinesTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/yds_liveness_guidelines_header"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/appBar"
                style="@style/Yds.TextView.Title"/>
            <TextView
                android:id="@+id/livenessGuidelinesDescriptionFirst"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/yds_margin"
                app:layout_constraintEnd_toEndOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintStart_toStartOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintTop_toBottomOf="@+id/livenessGuidelinesTitle"
                style="@style/Yds.TextView.Text"/>
            <ImageView
                android:id="@+id/livenessGuidelinesImageRowFirstStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:layout_constraintStart_toStartOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintTop_toBottomOf="@+id/livenessGuidelinesDescriptionFirst"/>
            <ImageView
                android:id="@+id/livenessGuidelinesImageRowFirstEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                app:layout_constraintStart_toEndOf="@+id/livenessGuidelinesImageRowFirstStart"
                app:layout_constraintTop_toTopOf="@+id/livenessGuidelinesImageRowFirstStart"/>
            <TextView
                android:id="@+id/livenessGuidelinesDescriptionSecond"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintStart_toStartOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintTop_toBottomOf="@+id/livenessGuidelinesImageRowFirstStart"
                style="@style/Yds.TextView.Text"/>
            <ImageView
                android:id="@+id/livenessGuidelinesImageRowSecondStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/yds_vertical_margin"
                app:layout_constraintStart_toStartOf="@+id/livenessGuidelinesTitle"
                app:layout_constraintTop_toBottomOf="@+id/livenessGuidelinesDescriptionSecond"/>
            <ImageView
                android:id="@+id/livenessGuidelinesImageRowSecondEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@+id/livenessGuidelinesImageRowFirstEnd"
                app:layout_constraintTop_toTopOf="@+id/livenessGuidelinesImageRowSecondStart"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <View
        android:id="@+id/shadow"
        android:layout_width="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/scrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/Yds.ScrollViewShadow"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:id="@+id/buttonLivenessGuidelinesGotIt"
        android:layout_width="0dp"
        android:layout_margin="@dimen/yds_margin"
        android:text="@string/yds_common_got_it"
        app:icon="@drawable/icon_tick"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView"
        style="@style/Yds.Button.Primary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
