<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/review_document_container"
    android:paddingTop="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/drag_indicator"
        android:background="@drawable/yds_rounded_square"
        android:layout_width="32dp"
        android:layout_height="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ViewSwitcher
        android:id="@+id/reviewGuidelineFlipper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/drag_indicator">
        <include
            android:id="@+id/review"
            layout="@layout/yds_review_screen"/>
        <include
            android:id="@+id/guidelines"
            layout="@layout/yds_fragment_id_document_guidelines"/>
    </ViewSwitcher>
</androidx.constraintlayout.widget.ConstraintLayout>
