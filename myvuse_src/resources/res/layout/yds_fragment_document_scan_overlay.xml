<?xml version="1.0" encoding="utf-8"?>
<com.yoti.mobile.android.documentcapture.p055id.view.scan.OverlayScanView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.yoti.mobile.android.documentscan.ui.helpers.scan.DocumentScanOverlayView
        android:id="@+id/scanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/logo"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginTop="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/scanTextsFrame"
        android:background="@color/yoti_white"
        android:layout_width="0dp"
        android:layout_height="245dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/scanTextTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/scanTextsFrame"
        style="@style/Yds.TextView.Title"/>
    <TextView
        android:id="@+id/scanTextSubTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="@+id/scanTextTitle"
        app:layout_constraintStart_toStartOf="@+id/scanTextTitle"
        app:layout_constraintTop_toBottomOf="@+id/scanTextTitle"
        style="@style/Yds.TextView.Text"/>
    <ImageButton
        android:id="@+id/manualCaptureBtn"
        android:background="@drawable/yds_camera_button"
        android:visibility="invisible"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/yds_ic_ico_camera"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</com.yoti.mobile.android.documentcapture.p055id.view.scan.OverlayScanView>
