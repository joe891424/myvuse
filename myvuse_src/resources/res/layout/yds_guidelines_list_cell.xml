<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/yds_guidelines_list_cell_bottom_margin">
    <ImageView
        android:id="@+id/guidelinesItemImage"
        android:layout_width="@dimen/yds_guidelines_list_cell_image_size"
        android:layout_height="@dimen/yds_guidelines_list_cell_image_size"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/guidelinesItemHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/yds_guidelines_list_cell_text_from_image_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guidelinesItemImage"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Yds.TextView.Header"/>
    <TextView
        android:id="@+id/guidelinesItemText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guidelinesItemHeader"
        app:layout_constraintTop_toBottomOf="@+id/guidelinesItemHeader"
        style="@style/Yds.TextView.Text"/>
</androidx.constraintlayout.widget.ConstraintLayout>
