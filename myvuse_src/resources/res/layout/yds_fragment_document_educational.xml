<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.Group
        android:id="@+id/loadingViewGroup"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="appBarLoading,loadingView,buttonStartScanLoading,buttonDoNotHaveLoading"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/successViewGroup"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="scrollView,buttonStartScan,buttonDoNotHave"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiAppbar
        android:id="@+id/appBarLoading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:id="@+id/loadingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonStartScanLoading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appBarLoading"
        layout="@layout/yds_fragment_document_educational_loading_state"/>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonStartScan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.yoti.mobile.android.common.p049ui.widgets.YotiAppbar
                android:id="@+id/appBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <include
                android:id="@+id/successView"
                layout="@layout/yds_fragment_document_educational_success_state"/>
        </LinearLayout>
    </ScrollView>
    <View
        android:id="@+id/shadow"
        android:layout_width="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/scrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/Yds.ScrollViewShadow"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:id="@+id/buttonStartScan"
        android:layout_width="0dp"
        android:layout_marginTop="@dimen/yds_margin"
        android:layout_marginBottom="4dp"
        android:layout_marginHorizontal="@dimen/yds_margin"
        app:icon="@drawable/yds_ic_ico_chevron_right"
        app:layout_constraintBottom_toTopOf="@+id/buttonDoNotHave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView"
        app:layout_goneMarginBottom="@dimen/yds_margin"
        style="@style/Yds.Button.Primary"/>
    <View
        android:id="@+id/buttonStartScanLoading"
        android:layout_height="52dp"
        android:layout_marginTop="@dimen/yds_margin"
        android:layout_marginBottom="4dp"
        android:layout_marginHorizontal="@dimen/yds_margin"
        app:layout_constraintBottom_toTopOf="@+id/buttonDoNotHaveLoading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/loadingView"
        app:layout_goneMarginBottom="@dimen/yds_margin"
        style="@style/Yds.LoadingView.Landing"/>
    <com.yoti.mobile.android.common.p049ui.widgets.YotiButton
        android:id="@+id/buttonDoNotHave"
        android:layout_width="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="@dimen/yds_margin"
        android:layout_marginHorizontal="@dimen/yds_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonStartScan"
        style="@style/Yds.Button.Secondary"/>
    <View
        android:id="@+id/buttonDoNotHaveLoading"
        android:layout_height="52dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="@dimen/yds_margin"
        android:layout_marginHorizontal="@dimen/yds_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonStartScanLoading"
        style="@style/Yds.LoadingView.Landing"/>
</androidx.constraintlayout.widget.ConstraintLayout>
