<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/yds_document_requirements_cell_bottom_margin">
    <ImageView
        android:id="@+id/imageViewRequirementsItem"
        android:layout_width="22dp"
        android:layout_height="22dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/textViewRequirementsItemHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toTopOf="@+id/textViewRequirementsItemText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imageViewRequirementsItem"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Yds.TextView.Header"/>
    <TextView
        android:id="@+id/textViewRequirementsItemText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/textViewRequirementsItemTextSecondary"
        app:layout_constraintEnd_toEndOf="@+id/textViewRequirementsItemHeader"
        app:layout_constraintStart_toStartOf="@+id/textViewRequirementsItemHeader"
        app:layout_constraintTop_toBottomOf="@+id/textViewRequirementsItemHeader"
        style="@style/Yds.TextView.Text"/>
    <TextView
        android:id="@+id/textViewRequirementsItemTextSecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/textViewRequirementsItemHeader"
        app:layout_constraintStart_toStartOf="@+id/textViewRequirementsItemHeader"
        app:layout_constraintTop_toBottomOf="@+id/textViewRequirementsItemText"
        style="@style/Yds.TextView.Text"/>
</androidx.constraintlayout.widget.ConstraintLayout>
