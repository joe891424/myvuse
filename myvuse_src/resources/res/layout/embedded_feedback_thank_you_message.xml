<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/embeddedFeedbackThankYouMessageBody"
    android:background="@drawable/embedded_feedback_modal_border"
    android:focusable="false"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="16dp"
        android:layout_weight="0.6">
        <ImageButton
            android:id="@+id/close_button"
            android:background="#ffffff"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/close_16dp"
            android:layout_alignParentRight="true"
            android:contentDescription="@string/qualtrics_close_button"/>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="20sp"
            android:layout_gravity="center"
            android:id="@+id/thank_you_message"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thank you for your response"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</LinearLayout>
