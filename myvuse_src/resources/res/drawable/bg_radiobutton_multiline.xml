<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <ripple android:color="?attr/background_emphasis">
            <item>
                <selector>
                    <item android:state_enabled="false">
                        <shape android:shape="rectangle">
                            <solid
                                android:color="?attr/background_neutral1"
                                android:alpha="0.5"/>
                            <corners android:radius="@dimen/radiobutton_corner"/>
                        </shape>
                    </item>
                    <item>
                        <shape android:shape="rectangle">
                            <solid android:color="?attr/background_neutral1"/>
                            <corners android:radius="@dimen/radiobutton_corner"/>
                        </shape>
                    </item>
                </selector>
            </item>
        </ripple>
    </item>
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radiobutton_corner"/>
                    <stroke
                        android:width="@dimen/radiobutton_border"
                        android:color="?attr/border_disabled"/>
                </shape>
            </item>
            <item android:state_checked="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radiobutton_corner"/>
                    <stroke
                        android:width="@dimen/radiobutton_selected_border"
                        android:color="?attr/border_focus"/>
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radiobutton_corner"/>
                    <stroke
                        android:width="@dimen/radiobutton_selected_border"
                        android:color="?attr/border_focus"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radiobutton_corner"/>
                    <stroke
                        android:width="@dimen/radiobutton_border"
                        android:color="?attr/border_default"/>
                </shape>
            </item>
        </selector>
    </item>
</layer-list>
