<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <ripple android:color="?attr/background_emphasis">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?attr/background_neutral1"/>
                    <corners
                        android:topLeftRadius="@dimen/button_corner_radius"
                        android:topRightRadius="@dimen/button_corner_radius"/>
                </shape>
            </item>
        </ripple>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="@dimen/button_corner_radius"
                android:topRightRadius="@dimen/button_corner_radius"/>
            <stroke
                android:width="2dp"
                android:color="?attr/border_default"/>
        </shape>
    </item>
</layer-list>
